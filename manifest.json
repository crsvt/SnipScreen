{
  "manifest_version": 3,
  "name": "SnipScreen",
  "version": "1.1",
  "description": "Capture, crop, black out, and annotate screenshots with red arrows and text, then copy or save them",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs",
    "notifications",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Take Screenshot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}